# Copy this file to ".env.release" (which is gitignored) and fill in your values.
# release.sh loads it automatically, so you never have to `export` these by hand.
#
#   cp .env.release.example .env.release
#   # then edit .env.release with your real values
#
# Get an app-specific password at appleid.apple.com → Sign-In & Security → App-Specific Passwords.

APPLE_ID="you@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="ABCDE12345"
